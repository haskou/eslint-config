{
  "name": "@haskou/eslint-config",
  "version": "0.2.1",
  "description": "Shared ESLint and Prettier configuration for strict TypeScript projects",
  "type": "module",
  "license": "MIT",
  "author": "Haskou",
  "sideEffects": false,
  "homepage": "https://github.com/haskou/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haskou/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/haskou/eslint-config/issues"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "typescript",
    "prettier",
    "haskou"
  ],
  "exports": {
    ".": "./index.mjs",
    "./base": "./base.mjs",
    "./prettier": "./prettier.mjs"
  },
  "files": [
    "base.mjs",
    "index.mjs",
    "prettier.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.20.2"
  },
  "scripts": {
    "lint": "eslint .",
    "pack:dry": "npm pack --dry-run"
  },
  "peerDependencies": {
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "typescript": ">=5.5.0"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
